# ILMA Frontend Environment Variables
# Copy to .env.local and fill in values

# API — In dev, Vite proxy forwards /api to backend (see vite.config.ts)
# Use /api/v1 for local dev, full URL for staging/prod
VITE_API_URL=/api/v1

# Observability
VITE_SENTRY_DSN=

# Feature Flags (optional remote endpoint)
VITE_FLAGS_URL=
